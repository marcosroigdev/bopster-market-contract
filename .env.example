############################################
# GLOBAL
############################################

DEPLOY_MARKET=false

############################################
# NETWORK / DEPLOYMENT
############################################

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Private key of the deployer account (NO 0x prefix is also OK).
# ⚠️ NEVER COMMIT A REAL KEY. Use a dedicated, low-value deployer wallet.
DEPLOYER_PRIVATE_KEY=""

# Block explorer API key used by hardhat-verify for contract verification.
BASESCAN_API_KEY=""

############################################
# CONTRACT ADDRESSES
############################################

# ERC20 token used for betting (USDC)
USDC_ADDRESS=""

# Reality.eth contract address (or MockReality)
REALITY_ADDRESS=""

# Treasury wallet (protocol fees receiver)
TREASURY_ADDRESS=""

############################################
# REALITY QUESTION
############################################

# Reality.eth questionId (bytes32)
QUESTION_ID=""

############################################
# MARKET METADATA
############################################

# Off-chain metadata (IPFS or HTTPS)
METADATA_URI=""

############################################
# MARKET TIMING (UNIX TIMESTAMPS - SECONDS)
############################################

# Betting closes
END_TIME=""

# Resolution can start AFTER this moment
RESOLVE_TIME=""

############################################
# FEES (BASIS POINTS) — total must be <= 1000 (10%)
############################################

PROTOCOL_FEE_BPS="200"        # 2.00%
CREATOR_FEE_BPS="100"         # 1.00%
RESOLVER_REWARD_BPS="20"      # 0.20%

############################################
# FACTORY DEPLOY PARAMS
############################################

FACTORY_TOKEN_ADDRESS=""      # USDC or MockUSDC
FACTORY_REALITY_ADDRESS=""    # Reality or MockReality
FACTORY_TREASURY_ADDRESS=""   # Treasury/Safe
FACTORY_ADMIN_ADDRESS=""      # Admin (recommended: a multisig)

# Default fee schedule (bps)
FACTORY_PROTOCOL_FEE_BPS="200"      # 2%
FACTORY_CREATOR_FEE_BPS="100"       # 1%
FACTORY_RESOLVER_REWARD_BPS="20"    # 0.2%
