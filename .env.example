############################################
# NETWORK / DEPLOYMENT
############################################

# Base mainnet RPC (Alchemy / Infura / QuickNode — do NOT use public endpoint)
BASE_RPC_URL=""

# Base Sepolia RPC (testnet)
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Deployer private key. ⚠️ NEVER COMMIT A REAL KEY.
# Use a dedicated, low-value deployer wallet.
PRIVATE_KEY=""

# Block explorer API key for contract verification
BASESCAN_API_KEY=""

############################################
# FACTORY CONSTRUCTOR ARGS
############################################

# ERC20 token used for betting — canonical native USDC on Base
# Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
TOKEN_ADDRESS=""

# Reality.eth ERC20 v3 address on Base
# Verify against https://github.com/RealityETH/reality-eth-monorepo
REALITY_ADDRESS=""

# Treasury wallet — receives protocol fees. IMMUTABLE after deploy.
# Use a multisig or cold wallet, NOT the admin Safe.
TREASURY_ADDRESS=""

# Admin address — becomes factory.owner(). Recommended: a multisig (Safe).
# Rotatable via Ownable2Step; treasury is NOT rotatable.
ADMIN_ADDRESS=""

# Fee schedule (basis points; sum must be <= 1000 = 10%)
PROTOCOL_FEE_BPS="200"       # 2.00%  — sent to treasury
CREATOR_FEE_BPS="100"        # 1.00%  — sent to market creator
RESOLVER_REWARD_BPS="20"     # 0.20%  — sent to finalize() caller

############################################
# MARKET CREATION (one-off; not needed for factory deploy)
############################################

# Reality.eth questionId (bytes32)
QUESTION_ID=""

# Off-chain metadata (IPFS or HTTPS)
METADATA_URI=""

# Market timing (unix timestamps — seconds)
END_TIME=""
RESOLVE_TIME=""
